{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "D=\"${CLAUDE_PROJECT_DIR:-/Users/iftachorr/קרקסון }\"; jq -c --arg ts \"$(date -u +%FT%TZ)\" '{ts: $ts, prompt: .prompt}' >> \"$D/memory/prompts.jsonl\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "D=\"${CLAUDE_PROJECT_DIR:-/Users/iftachorr/קרקסון }\"; jq -c --arg ts \"$(date -u +%FT%TZ)\" '{ts: $ts, type: \"stop\"}' >> \"$D/memory/prompts.jsonl\""
          }
        ]
      }
    ]
  }
}
